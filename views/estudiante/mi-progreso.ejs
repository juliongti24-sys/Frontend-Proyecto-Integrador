<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MathBoost – Mi Progreso</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/estudiante.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="estudiante-body">

  <%- include('../partials/sidebar-estudiante', { active: 'progreso' }) %>

  <div class="main-content">

    <!-- Header interno -->
    <header class="inner-header">
      <div class="user-info">
        <div class="user-avatar">E</div>
        <span class="user-name" id="nombreUsuario">Estudiante</span>
      </div>
      <button class="btn-manual">
        <i class="fas fa-book-open"></i> Manual de usuario
      </button>
    </header>

    <div class="content-area">

      <!-- Botón regresar -->
      <a href="/estudiante/dashboard" class="btn-back">
        <i class="fas fa-arrow-left"></i> Regresar al inicio
      </a>

      <!-- Encabezado -->
      <div class="page-header">
        <div>
          <h1>Mi Progreso</h1>
          <p>Consulta tus calificaciones y avance general</p>
        </div>
      </div>

      <!-- Tarjetas resumen -->
      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-value" id="statPromedio">–</div>
          <div class="stat-label">Promedio general</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" id="statActividades">–</div>
          <div class="stat-label">Actividades completadas</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" id="statTrayectoria">–</div>
          <div class="stat-label">Avance trayectoria</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" id="statRacha">–</div>
          <div class="stat-label">Días de racha</div>
        </div>
      </div>

      <!-- Gráficas -->
      <div class="charts-grid">

        <div class="chart-card">
          <h3><i class="fas fa-chart-bar"></i> Calificaciones por parcial</h3>
          <canvas id="chartParciales"></canvas>
        </div>

        <div class="chart-card">
          <h3><i class="fas fa-chart-line"></i> Progreso general</h3>
          <canvas id="chartGeneral"></canvas>
        </div>

        <div class="chart-card">
          <h3><i class="fas fa-route"></i> Avance en trayectoria</h3>
          <canvas id="chartTrayectoria"></canvas>
        </div>

        <div class="chart-card">
          <h3><i class="fas fa-list-check"></i> Actividades por clase</h3>
          <canvas id="chartActividades"></canvas>
        </div>

      </div>

    </div>
  </div>

  <script src="/js/mi-progreso.js"></script>
  <script src="/js/sesion-estudiante.js"></script>

</body>
</html>