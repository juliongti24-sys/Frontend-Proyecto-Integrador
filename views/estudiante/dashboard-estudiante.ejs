<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MathBoost – Dashboard Estudiante</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/estudiante.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body class="estudiante-body">

  <%- include('../partials/sidebar-estudiante', { active: 'inicio' }) %>

  <div class="main-content">

    <!-- Header interno -->
    <header class="inner-header">
      <div class="user-info">
        <div class="user-avatar">E</div>
        <span class="user-name" id="nombreUsuario">Estudiante</span>
      </div>
      <button class="btn-manual">
        <i class="fas fa-book-open"></i> Manual de usuario
      </button>
    </header>

    <div class="content-area">

      <!-- Encabezado -->
      <div class="page-header">
        <div>
          <h1>Mis Clases</h1>
          <p>Accede a tus clases inscritas</p>
        </div>
        <button class="btn-primary" id="btnUnirse">
          <i class="fas fa-plus"></i> Unirse a clase
        </button>
      </div>

      <!-- Grid de clases -->
      <div class="classes-grid" id="clasesGrid">
        <!-- Las clases se cargarán desde la API -->
      </div>

    </div>
  </div>

  <!-- ── Modal Unirse a clase ── -->
  <div class="modal-overlay" id="modalUnirse">
    <div class="modal">
      <div class="modal-header">
        <h2><i class="fas fa-right-to-bracket"></i> Unirse a clase</h2>
        <button class="modal-close" id="cerrarUnirse">
          <i class="fas fa-xmark"></i>
        </button>
      </div>

      <p style="color:#9ca3af; margin-bottom:1.2rem;">
        Ingresa el código que te compartió tu maestro para unirte a la clase.
      </p>

      <div class="form-group">
        <label>Código de clase</label>
        <input
          type="text"
          id="codigoClase"
          placeholder="Ej. AB12CD"
          maxlength="6"
          style="
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-family: monospace;
            font-size: 1.1rem;
            width: 100%;
            padding: 0.7rem 1rem;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(251,191,36,0.15);
            border-radius: 10px;
            color: #f1f0f5;
            outline: none;
            box-sizing: border-box;
          "
        />
      </div>

      <div class="modal-footer">
        <button class="btn-secondary" id="cancelarUnirse">Cancelar</button>
        <button class="btn-primary" id="confirmarUnirse">
          <i class="fas fa-check"></i> Unirse
        </button>
      </div>
    </div>
  </div>

  <script src="/js/dashboard-estudiante.js"></script>
  <script src="/js/sesion-estudiante.js"></script>

</body>
</html>