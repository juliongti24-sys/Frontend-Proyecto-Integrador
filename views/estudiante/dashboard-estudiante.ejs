<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MathBoost – Dashboard Estudiante</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/estudiante.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body class="estudiante-body">

  <%- include('../partials/sidebar-estudiante', { active: 'inicio' }) %>

  <div class="main-content">

    <!-- Header interno -->
    <header class="inner-header">
      <div class="user-info">
        <div class="user-avatar">E</div>
        <span class="user-name" id="nombreUsuario">Estudiante</span>
      </div>
      <button class="btn-manual">
        <i class="fas fa-book-open"></i> Manual de usuario
      </button>
    </header>

    <div class="content-area">

      <!-- Catálogo de Cursos (Estilo Coursera) -->
      <div class="page-header" style="margin-top: 0;">
        <div>
          <h1>Explora nuestros cursos</h1>
          <p>Potencia tus habilidades matemáticas con contenido estructurado</p>
        </div>
      </div>
      
      <div class="courses-grid" id="cursosGrid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
        <!-- Los cursos se cargarán desde la API -->
      </div>

    </div>
  </div>

  <!-- ── Modal Detalles de Curso ── -->
  <div id="modalDetallesCurso" class="modal-overlay">
    <div class="modal-content" style="max-width: 600px;">
      <div class="modal-header">
        <h2 id="modalDetallesTitulo">Detalles del Curso</h2>
        <button class="close-modal" onclick="cerrarModal('modalDetallesCurso')">&times;</button>
      </div>
      <div class="modal-body" id="modalDetallesCuerpo">
        <!-- JS inyecta datos aquí -->
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" onclick="cerrarModal('modalDetallesCurso')">Cerrar</button>
        <button class="btn-primary" id="btnInscribirse">Inscribirme ahora</button>
      </div>
    </div>
  </div>

  <script src="/js/dashboard-estudiante.js"></script>
  <script src="/js/sesion-estudiante.js"></script>

</body>
</html>