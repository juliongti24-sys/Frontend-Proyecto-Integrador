<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MathBoost – Desafío Matemático</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/estudiante.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  <style>
    .challenge-page-container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 2rem;
    }

    /* Challenge Card */
    .challenge-card {
        background: var(--surface-color);
        border-radius: 20px;
        padding: 3rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        text-align: center;
        min-height: 500px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .challenge-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 6px;
        background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
    }

    /* Lobby State */
    .lobby-state img {
        width: 150px;
        margin-bottom: 2rem;
        animation: float 3s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }

    .queue-timer {
        font-size: 1.2rem;
        color: var(--primary-color);
        font-weight: 600;
        margin-top: 1rem;
    }

    /* Game State */
    .game-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
    }

    .player-vs {
        display: flex;
        align-items: center;
        gap: 2rem;
        justify-content: center;
        margin-bottom: 3rem;
    }

    .player-box {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
    }

    .vs-badge {
        background: var(--primary-color);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 50px;
        font-weight: 800;
        font-size: 0.9rem;
    }

    .avatar-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid var(--border-color);
        background: var(--bg-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-color);
        transition: transform 0.3s;
    }

    .player-box.active .avatar-circle {
        border-color: var(--primary-color);
        transform: scale(1.1);
    }

    .math-question {
        font-size: 4.5rem;
        font-weight: 800;
        color: var(--text-color);
        margin: 2rem 0;
        font-family: 'Inter', sans-serif;
    }

    .options-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .option-btn {
        background: var(--bg-color);
        border: 2px solid var(--border-color);
        padding: 1.5rem;
        border-radius: 15px;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--text-color);
        cursor: pointer;
        transition: all 0.2s;
    }

    .option-btn:hover {
        border-color: var(--primary-color);
        background: rgba(79, 70, 229, 0.05);
        transform: translateY(-3px);
    }

    .option-btn.correct {
        background: #10b981;
        border-color: #10b981;
        color: white;
    }

    .option-btn.wrong {
        background: #ef4444;
        border-color: #ef4444;
        color: white;
    }

    /* Results */
    .winner-trophy {
        font-size: 6rem;
        color: #f59e0b;
        margin-bottom: 1rem;
    }

    .score-summary {
        margin: 2rem 0;
        padding: 1.5rem;
        background: var(--bg-color);
        border-radius: 15px;
    }

  </style>
</head>
<body class="estudiante-body">

  <%- include('../partials/sidebar-estudiante', { active: active }) %>

  <div class="main-content">
    <header class="inner-header">
      <div class="user-info">
        <div id="headerAvatar" class="avatar-small">
            <img src="<%= user.foto_perfil || '' %>" alt="" style="<%= user.foto_perfil ? '' : 'display:none' %>">
            <span style="<%= user.foto_perfil ? 'display:none' : '' %>"><%= user.nombre.charAt(0) %></span>
        </div>
        <span class="user-name"><%= user.nombre %></span>
      </div>
    </header>

    <div class="challenge-page-container">
      
      <div id="lobbySection" class="challenge-card">
        <div class="lobby-state">
            <i class="fas fa-rocket winner-trophy" style="font-size: 8rem; color: var(--primary-color);"></i>
            <h1 style="font-size: 2.5rem; margin: 1.5rem 0;">Desafío Relámpago</h1>
            <p style="color: var(--text-muted); font-size: 1.2rem; max-width: 500px; margin: 0 auto 2rem;">
                Compite contra otro estudiante en tiempo real resolviendo ejercicios matemáticos aleatorios.
            </p>
            
            <button id="btnStartQueue" class="btn-primary" style="font-size: 1.2rem; padding: 1.2rem 3rem; border-radius: 50px;">
                <i class="fas fa-play"></i> Buscar Partida
            </button>

            <div id="searchingState" style="display: none; margin-top: 2rem;">
                <div class="queue-timer">Buscando oponente... <span id="timer">00:00</span></div>
                <div style="margin-top: 1rem;">
                    <i class="fas fa-circle-notch fa-spin" style="font-size: 2rem; color: var(--primary-color);"></i>
                </div>
                <button id="btnCancelQueue" class="btn-secondary" style="margin-top: 2rem; border-radius: 50px;">
                    Cancelar búsqueda
                </button>
            </div>
        </div>
      </div>

      <div id="gameSection" class="challenge-card" style="display: none;">
        <div class="game-header">
            <div style="text-align: left;">
                <span id="questionCount" style="background: var(--bg-color); padding: 0.5rem 1rem; border-radius: 50px; font-weight: 600;">Pregunta 1/5</span>
            </div>
            <div id="gameTimer" style="font-weight: 700; color: #ef4444; font-size: 1.2rem;">
                <i class="fas fa-clock"></i> <span id="timeRemaining">15s</span>
            </div>
        </div>

        <div class="player-vs">
            <div class="player-box" id="p1Box">
                <div class="avatar-circle" id="p1Avatar">?</div>
                <span style="font-weight: 600;" id="p1Name">Tú</span>
                <span class="badge badge-active" id="p1Score">0 pts</span>
            </div>
            
            <div class="vs-badge">VS</div>

            <div class="player-box" id="p2Box">
                <div class="avatar-circle" id="p2Avatar">?</div>
                <span style="font-weight: 600;" id="p2Name">Oponente</span>
                <span class="badge badge-active" id="p2Score">0 pts</span>
            </div>
        </div>

        <div id="questionArea">
            <div class="math-question" id="displayQuestion">24 + 16</div>
            <div class="options-grid" id="optionsContainer">
                <!-- Botones de opciones se inyectan aquí -->
            </div>
        </div>

        <div id="feedbackMsg" style="margin-top: 2rem; font-size: 1.5rem; font-weight: 700;"></div>
      </div>

      <div id="resultsSection" class="challenge-card" style="display: none;">
        <div id="resultContent">
            <i class="fas fa-trophy winner-trophy"></i>
            <h1 id="resultTitle">¡Felicidades!</h1>
            <p id="resultSubtitle" style="font-size: 1.2rem; margin-bottom: 2rem;">Has ganado el desafío contra [Oponente]</p>
            
            <div class="score-summary">
                <div style="display:flex; justify-content: space-around; font-size: 1.5rem;">
                    <div>Tu puntaje: <strong id="finalMyScore">0</strong></div>
                    <div>Oponente: <strong id="finalOpScore">0</strong></div>
                </div>
            </div>

            <button onclick="location.reload()" class="btn-primary" style="padding: 1rem 3rem; border-radius: 50px;">
                <i class="fas fa-redo"></i> Volver a jugar
            </button>
        </div>
      </div>

    </div>
  </div>

  <script src="/js/desafio.js"></script>
</body>
</html>
