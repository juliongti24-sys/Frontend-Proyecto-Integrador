<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>MathBoost – Clase</title>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/estudiante.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body class="estudiante-body">

  <%- include('../partials/sidebar-estudiante', { active: 'clases' }) %>

  <div class="main-content">

    <!-- Header interno -->
    <header class="inner-header">
      <div class="user-info">
        <div class="user-avatar">E</div>
        <span class="user-name" id="nombreUsuario">Estudiante</span>
      </div>
      <button class="btn-manual">
        <i class="fas fa-book-open"></i> Manual de usuario
      </button>
    </header>

    <div class="content-area">

      <!-- Botón regresar -->
      <a href="/estudiante/dashboard" class="btn-back">
        <i class="fas fa-arrow-left"></i> Regresar a mis clases
      </a>

      <!-- Encabezado de la clase -->
      <div class="page-header">
        <div>
          <h1 id="claseNombre">Nombre de la clase</h1>
          <p id="claseMaestro">Maestro: –</p>
        </div>
        <div class="class-code">
          <i class="fas fa-key"></i>
          <span id="claseCodigo">––––––</span>
        </div>
      </div>

      <!-- Lista de actividades y avisos -->
      <div class="activity-list" id="listaActividades">
        <!-- Las actividades se cargarán desde la API -->
      </div>

    </div>
  </div>

  <script src="/js/clase-estudiante.js"></script>
  <script src="/js/sesion-estudiante.js"></script>
</body>
</html>